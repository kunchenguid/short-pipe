{
  "name": "short-pipe",
  "version": "0.0.7",
  "description": "Local-first Electron app that turns long-form video into captioned vertical shorts, powered by your own Codex subscription.",
  "license": "MIT",
  "author": "Kun Chen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kunchenguid/short-pipe.git"
  },
  "homepage": "https://github.com/kunchenguid/short-pipe",
  "bugs": "https://github.com/kunchenguid/short-pipe/issues",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "main": "./out/main/index.js",
  "scripts": {
    "preinstall": "node scripts/ensure-pnpm.mjs",
    "predev": "node scripts/ensure-pnpm.mjs",
    "dev": "bash scripts/dev.sh",
    "prebuild": "node scripts/ensure-pnpm.mjs",
    "build": "electron-vite build",
    "prestart": "node scripts/ensure-pnpm.mjs",
    "start": "electron-vite preview",
    "pretypecheck": "node scripts/ensure-pnpm.mjs",
    "typecheck": "tsc -b --pretty",
    "pretest": "node scripts/ensure-pnpm.mjs",
    "test": "vitest run",
    "pretest:watch": "node scripts/ensure-pnpm.mjs",
    "test:watch": "vitest",
    "prelint": "node scripts/ensure-pnpm.mjs",
    "lint": "biome lint .",
    "preformat": "node scripts/ensure-pnpm.mjs",
    "format": "biome format --write .",
    "precheck": "node scripts/ensure-pnpm.mjs",
    "check": "biome check .",
    "predist": "node scripts/ensure-pnpm.mjs",
    "dist": "electron-vite build && electron-builder",
    "preverify:asar": "node scripts/ensure-pnpm.mjs",
    "verify:asar": "node scripts/verify-asar-deps.mjs dist",
    "prepackage:mac": "node scripts/ensure-pnpm.mjs",
    "package:mac": "rm -rf dist && pnpm build && electron-builder --mac dir --universal --config electron-builder.dev.yml && pnpm verify:asar && node scripts/adhoc-sign-mac-app.mjs \"dist/mac-universal/Short Pipe Dev.app\"",
    "predist:mac": "node scripts/ensure-pnpm.mjs",
    "dist:mac": "pnpm package:mac && node scripts/create-dmg.mjs \"dist/mac-universal/Short Pipe Dev.app\"",
    "predist:dir": "node scripts/ensure-pnpm.mjs",
    "dist:dir": "electron-vite build && electron-builder --dir"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.75.3",
    "@earendil-works/pi-coding-agent": "^0.75.3",
    "gsap": "3.14.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@electron/asar": "^3.4.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.15.0",
    "electron-vite": "^5.0.0",
    "jsdom": "^28.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.0"
  }
}
